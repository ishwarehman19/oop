#include<iostream>
using namespace std;

class employee{
	protected:
		string name;
		int id;
		double baseSalary;
		
		public:
			empolyee(string n,int i,double b){
				name=n;
				id=i;
				baseSalary=b;
				}
			
			~employee(){
			
			}
			virtual double calculatepay()=0;
				
			void displayInfo(){
				cout<<"Name :"<<name<<"\n ID: "<<id<<"\n Base salary :"<<baseSalary<<endl;
			}
};

class salariedEmployee: public employee{
	private:
		double annualBonus;
		public:
			salariedEmployee(string n,int i,double b,double a){
				name=n;
				id=i;
				baseSalary=b;
				annualBonus=a;
			}
			
			~salariedEmployee(){
				
			}
				
			double calculatepay()override{
				double pay = baseSalary + (annualBonus / 12);
				return pay;
		}
};
class HourlyEmployee: public employee{
	private:
	int hoursWorked;
	double hourlyRate;
	public:
		HourlyEmployee(string n,int i,double b,int h,double r){
			name=n;
		    id=i;
		    baseSalary=b;
		    hoursWorked=h;
		    hourlyRate=r;
		}
		
		~HourlyEmployee(){
			
		}
	 	double calculatepay()override{
	 	 double worked=hourlyRate * hoursWorked;
	 	 return worked;
		 }	
};

int main(){
	salariedEmployee S={"Ishwa",67,6500.0,10000.0};
    HourlyEmployee H={"zara", 78, 560.0, 7, 900.0};
	
	S.calculatepay();
	cout<<"Ishwa pay: "<<S.calculatepay()<<endl;
	
	H.calculatepay();
	cout<<"zara pay: "<<H.calculatepay()<<endl;
	
	return 0;
	
	
}
