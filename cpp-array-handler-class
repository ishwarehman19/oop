#include<iostream>
using namespace std;

class array{
	int num[5];
	
	public:
		array(){
			for (int i=0;i<5;i++){
				num[i]=0;
			}
		}
		void input(){
			cout<<"enter 5 numbers "<<endl;
			for(int i= 0;i<5;i++){
				cin>>num[i];
			}
		}
		void display(){
			cout<<"numbers are "<<endl;
			for(int i=0;i<5;i++){
				cout<<num [i] <<" ";
			}
			return ;
		}
		int findmax(){
			int max=num[0];
			for(int i =0;i<5;i++){
				if(num[i]>max){
					max=num[i];
				}
			}
			return max;
		}
};
int main(){
	array N;
	N.input();
	N.display();
	cout<<"max number is "<<N.findmax()<<endl;
	 return 0;
}
